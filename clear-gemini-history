#!/bin/python3

import time
import argparse
import sys
from pynput.keyboard import Key, Controller as KeyboardController, Listener
from pynput.mouse import Button, Controller as MouseController

# 初始化控制器
keyboard = KeyboardController()
mouse = MouseController()

def main():
    # 1. 设置命令行参数解析
    parser = argparse.ArgumentParser(
        description="模拟键盘鼠标循环脚本。支持特殊占位符: {ML}=左键, {MR}=右键",
        formatter_class=argparse.RawTextHelpFormatter
    )
    parser.add_argument(
        "-i", "--interval", 
        type=float, 
        default=1.0, 
        help="动作序列内部，每个按键/点击之间的时间间隔（秒），默认为 1.0"
    )
    parser.add_argument(
        "-d", "--delay", 
        type=float, 
        default=0.0, 
        help="两轮大循环之间的额外等待时间（秒），默认为 0.0"
    )
    parser.add_argument(
        "-s", "--sequence",
        type=str,
        default="{ML},f,s,f,s",
        help="按键序列，用逗号分隔。例如: {ML},f,{MR},s\n默认: {ML},f,s,f,s"
    )
    args = parser.parse_args()

    # 将输入的字符串转换为列表
    action_list = [item.strip() for item in args.sequence.split(',')]

    # 2. 定义全局控制变量
    state = {
        "is_running": False,
        "sequence": action_list,
        "interval": args.interval,
        "loop_delay": args.delay
    }

    print(f"--- 脚本已启动 ---")
    print(f"动作间距: {state['interval']}s | 循环间距: {state['loop_delay']}s")
    print(f"解析后的序列: {' -> '.join(state['sequence'])}")
    print("操作指南:")
    print("  - 特殊代码: {ML} = 鼠标左键 | {MR} = 鼠标右键")
    print("  - [Esc] 键 : 开始 / 停止循环")
    print("  - [Ctrl+C] : 退出脚本")
    print("------------------")

    def on_press(key):
        if key == Key.esc:
            state["is_running"] = not state["is_running"]
            status = "▶ 开始" if state["is_running"] else "■ 停止"
            print(f"\n[状态] {status} ")

    # 响应式等待函数 (支持秒停)
    def responsive_sleep(duration):
        stop_time = time.time() + duration
        while time.time() < stop_time:
            if not state["is_running"]:
                return False
            time.sleep(0.02)
        return True

    # 3. 启动后台键盘监听
    listener = Listener(on_press=on_press)
    listener.start()

    try:
        while True:
            if state["is_running"]:
                # --- 开始执行一轮序列 ---
                for i, action in enumerate(state["sequence"]):
                    if not state["is_running"]:
                        break
                    
                    # 动作识别与执行
                    if action == '{ML}':
                        print(f"动作: 鼠标左键 [Click]   ", end="\r")
                        mouse.click(Button.left, 1)
                    elif action == '{MR}':
                        print(f"动作: 鼠标右键 [Click]   ", end="\r")
                        mouse.click(Button.right, 1)
                    else:
                        print(f"动作: 键盘按键 [{action}]     ", end="\r")
                        try:
                            keyboard.press(action)
                            keyboard.release(action)
                        except Exception as e:
                            print(f"\n[错误] 无法按键 '{action}': {e}")
                    
                    # 序列内动作之间的间隔
                    # 如果是序列最后一个动作，就不在这里 sleep，而是去跑 loop_delay
                    if i < len(state["sequence"]) - 1:
                        if not responsive_sleep(state["interval"]):
                            break
                
                # --- 一轮序列结束，执行循环间延迟 ---
                if state["is_running"] and state["loop_delay"] > 0:
                    print(f"状态: 等待下一轮循环 ({state['loop_delay']}s)...", end="\r")
                    responsive_sleep(state["loop_delay"])
            else:
                time.sleep(0.1)
                
    except KeyboardInterrupt:
        print("\n[退出] 脚本已关闭。")
        sys.exit(0)

if __name__ == "__main__":
    main()
